SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
FROM_EMAIL=no-reply@example.com
FROM_NAME="Online Cinema"

SQL_ENGINE=django.db.backends.postgresql_psycopg2
DB_USER=
DB_PASSWORD=
DB_NAME=theatre

DB_HOST=theatre-db
DB_PORT=5432
SQL_OPTIONS=-c search_path=public,content
DATABASE_TYPE=postgres

AUTH_REDIS_PORT=6380
AUTH_DB_PORT=5433
AUTH_API_URL=http://auth-app:8002

AUTH_DB_USER=
AUTH_DB_PASSWORD=
AUTH_DB_NAME=auth
AUTH_DB_HOST=auth-db
DATABASE_URL=postgresql+asyncpg://${AUTH_DB_USER}:${AUTH_DB_PASSWORD}@${AUTH_DB_HOST}:${AUTH_DB_PORT}/${AUTH_DB_NAME}

JWT_ACCESS_SECRET=secret
JWT_REFRESH_SECRET=secret
JWT_OPTIONS="{'verify_signature': true, 'verify_exp': true, 'verify_nbf': true, 'verify_iat': true, 'verify_aud': true}"


REDIS_URL="redis://auth-redis:${AUTH_REDIS_PORT}"

KAFKA_BOOTSTRAP="kafka:9092"

ELK_URL=http://elasticsearch:9200
ELK_INDEX=movies
ELK_PORT=9200

SCHEMA_FILE=/opt/app/es_schema.json

REDIS_PORT=6379
REDIS_HOST=redis

S3_USER=minio
S3_PASSWORD=

PGADMIN_EMAIL=